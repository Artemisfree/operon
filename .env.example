NODE_ENV=development
API_PORT=3004
CATALOG_PROVIDER=local
FLOR_API_BASE_URL=http://localhost:8001
POSTGRES_DB=operon
POSTGRES_USER=operon
POSTGRES_PASSWORD=operon
POSTGRES_PORT=9432
# С хоста (Prisma/CLI на машине, Postgres в Docker): порт проброшен на 9432
DATABASE_URL=postgresql://operon:operon@127.0.0.1:9432/operon?schema=public
JWT_SECRET=change-me
AI_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_TIMEOUT_SECONDS=45
# Задержка перед автоматическим запросом отзыва в чате после delivered (минуты). По умолчанию 7.
REVIEW_DELAY_MINUTES=7
# Опционально: разрешённые Origin для браузера (через запятую). По умолчанию localhost:3001–3003.
# CORS_ORIGINS=http://localhost:3001,http://localhost:3002
